# Chat model endpoint.
OPENAI_BASE_URL=https://api.example.com
OPENAI_API_KEY=sk-...
OPENAI_MODEL=your-chat-model

# Optional compatibility alias used by some local agent runners.
OPENAI_CHAT_MODEL=your-chat-model

# Image generation endpoint.
OPENAI_IMAGE_BASE_URL=https://image-api.example.com/v1
OPENAI_IMAGE_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_AUTO_IMAGE_GENERATION=true

# Agent/runtime options.
OPENAI_THINKING_ENABLED=false
OPENAI_REASONING_EFFORT=
OPENAI_REQUEST_TIMEOUT_MS=120000
OPENAI_MAX_OUTPUT_TOKENS=16000
AGENT_EXEC_BASH_ENABLED=true
AGENT_AUTO_PDF_EXPORT=false
LIBREOFFICE_PATH=

# Comma-separated list of origins allowed to call /api/chat.
# Leave unset for local dev. Set this in production deployments.
# ALLOWED_ORIGINS=https://my-app.example.com,https://staging.example.com
